---
import WifiCard from '../components/WifiCard.jsx';
---

<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Benvenuti a La Volta di Chiara | Guest Info</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"></noscript>
</head>

<body class="pb-12 px-6">

<style>
    :root {
        --color-primary: #0f172a;
        --color-accent: #c5a368;
        --color-bg: #fdfcf9;
    }
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: var(--color-bg);
        color: var(--color-primary);
        -webkit-font-smoothing: antialiased;
    }
    .serif { font-family: 'Playfair Display', serif; }

    /* Animazioni entry */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in-up {
        animation: fadeInUp 0.6s ease-out forwards;
    }

    .delay-1 { animation-delay: 0.1s; opacity: 0; }
    .delay-2 { animation-delay: 0.2s; opacity: 0; }
    .delay-3 { animation-delay: 0.3s; opacity: 0; }
    .delay-4 { animation-delay: 0.4s; opacity: 0; }

    /* Link telefono pulse */
    @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }

    .phone-pulse:active {
        animation: pulse 0.3s ease-in-out;
    }
</style>

<main class="max-w-md mx-auto pt-16 md:pt-20">

    <header class="mb-16 text-center fade-in-up">
        <span class="text-[#c5a368] uppercase tracking-[0.4em] text-[9px] font-bold mb-6 block">Guest Concierge</span>

        <div class="inline-block border-y border-[#c5a368]/30 py-6 px-8">
            <h1 class="text-5xl md:text-6xl font-normal tracking-tighter leading-none serif italic text-[#0f172a]">
                La Volta <span class="text-[#c5a368] font-light">di Chiara</span>
            </h1>
        </div>

        <p class="text-[10px] text-slate-500 mt-6 uppercase tracking-[0.3em] font-light">Benvenuti nella vostra dimora</p>
    </header>

    <section class="mb-12 fade-in-up delay-1">
        <WifiCard client:load network="LaVoltaDiChiara_Guest" password="VoltadiChiara2026" />
    </section>

    <section class="space-y-6 mb-16">

        <div class="bg-white p-8 rounded-sm shadow-[0_10px_30px_rgba(15,23,42,0.04)] border border-slate-100 relative overflow-hidden fade-in-up delay-2">
            <div class="relative z-10">
                <div class="flex items-center gap-4 mb-5">
                    <div class="w-8 h-8 rounded-full bg-[#c5a368]/10 flex items-center justify-center">
                        <svg class="w-4 h-4 text-[#c5a368]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                        </svg>
                    </div>
                    <h3 class="text-[11px] font-bold uppercase tracking-[0.3em] text-[#0f172a]">Cucina & Lavanderia</h3>
                </div>
                <p class="text-sm text-slate-600 leading-relaxed font-light">
                    La cucina è a vostra completa disposizione. Vi chiediamo gentilmente di lasciarla in ordine per i prossimi ospiti. La <strong class="text-slate-900">lavasciuga professionale</strong> è disponibile ad uso gratuito.
                </p>
            </div>
            <div class="absolute -bottom-2 -right-2 text-slate-50 text-5xl font-black serif italic select-none opacity-50">C</div>
        </div>

        <div class="bg-gradient-to-br from-[#0f172a] to-[#1e293b] p-8 rounded-sm shadow-xl relative overflow-hidden text-white fade-in-up delay-3">
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-40"></div>

            <div class="relative z-10 flex items-start gap-5">
                <div class="pt-1 text-[#c5a368] flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#c5a368] mb-4">Check-out</h3>
                    <p class="text-white/90 text-sm font-light leading-relaxed mb-3">
                        Il check-out è previsto entro le <span class="text-white font-semibold text-base">10:30</span>
                    </p>
                    <p class="text-white/60 text-xs font-light italic">
                        Grazie per permetterci di preparare la dimora per i prossimi ospiti
                    </p>
                </div>
            </div>
        </div>

        <section class="mb-12 fade-in-up delay-3">
            <a href="INSERISCI_QUI_L_URL_COPIATO"
               target="_blank"
               rel="noopener"
               class="flex items-center justify-between bg-white border-2 border-[#c5a368] p-6 rounded-sm shadow-[0_15px_30px_rgba(197,163,104,0.15)] group transition-all hover:bg-[#c5a368] hover:text-white active:scale-95">
                <div class="flex items-center gap-5">
                    <div class="text-[#c5a368] group-hover:text-white transition-colors">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                        </svg>
                    </div>
                    <div class="text-left">
                        <h3 class="text-[11px] font-bold uppercase tracking-[0.3em] mb-1">Raccontaci il tuo soggiorno</h3>
                        <p class="text-xs opacity-70 font-light italic">Lasciaci una recensione su Google</p>
                    </div>
                </div>
                <div class="text-[#c5a368] group-hover:text-white transition-transform group-hover:translate-x-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </div>
            </a>
        </section>

        <div class="bg-[#c5a368]/5 border border-[#c5a368]/20 p-6 rounded-sm fade-in-up delay-4">
            <div class="flex items-start gap-4">
                <div class="text-[#c5a368] pt-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <h4 class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#c5a368] mb-2">Info Utili</h4>
                    <ul class="space-y-2 text-xs text-slate-600 font-light">
                        <li class="flex items-start gap-2">
                            <span class="text-[#c5a368] mt-1">•</span>
                            <span>Bidoni raccolta differenziata all'esterno</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="text-[#c5a368] mt-1">•</span>
                            <span>Cassetta sicurezza disponibile in camera</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="text-[#c5a368] mt-1">•</span>
                            <span>Chiavi da riconsegnare alla partenza</span>
                        </li>

                    </ul>
                </div>
            </div>
        </div>

    </section>

    <div class="text-center mt-16 pb-8">
        <p class="text-[9px] uppercase tracking-[0.3em] text-slate-400 mb-6 font-semibold">Per ogni necessità</p>

        <a href="tel:+393895804105"

           class="inline-flex items-center gap-4 bg-[#0f172a] text-white px-8 py-5 rounded-sm active:scale-95 transition-all shadow-lg phone-pulse group">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
            </div>
            <div class="text-left">
                <span class="block text-[9px] uppercase tracking-[0.3em] text-white/60 mb-1 font-bold">Chiama ora</span>
                <span class="block text-base font-semibold tracking-wide">+39 389 580 4105</span>

            </div>
        </a>

        <p class="text-[10px] text-slate-400 mt-6 italic">Risponderemo il prima possibile</p>
    </div>

</main>

<footer class="mt-20 pb-8 text-center">
    <div class="w-8 h-[1px] bg-[#c5a368] mx-auto mb-6 opacity-30"></div>
    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-[0.4em] italic">La Volta di Chiara · Roccaforzata</p>

</footer>

</body>
</html>
